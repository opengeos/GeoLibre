      "common": {
        "id": "osm-basemap",
        "name": "OpenStreetMap",
        "visible": true,
        "opacity": 1.0,
        "metadata": {}
      },
      "source": {
        "type": "xyz",
        "url": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
        "tile_type": "raster"
      },
      "maplibre_style_json": null
    }
  ],
  "active_layer_id": "sample-geojson",
  "maplibre_style_json": null
