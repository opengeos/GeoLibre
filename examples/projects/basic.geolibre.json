{
  "name": "Basic GeoLibre Project",
  "version": "0.1.0",
  "layers": [
    {
      "type": "vector",
      "common": {
        "id": "sample-geojson",
        "name": "Sample GeoJSON",
        "visible": true,
        "opacity": 1.0,
        "metadata": {}
      },
      "source": {
        "type": "geo_json",
        "path": "examples/data/sample.geojson"
      },
      "style": {
        "stroke_color": {
          "r": 42,
          "g": 104,
          "b": 186,
          "a": 255
